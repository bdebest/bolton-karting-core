<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bolton Karting Dashboard</title>
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>
  <div class="header">
    <h1>Bolton Karting Staff Dashboard</h1>
    <div class="user-info">
      <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=128" width="48" height="48" alt="PFP">
      <div>
        <strong><%= user.username %></strong><br>
        <small>ID: <%= user.id %></small>
      </div>
      <a href="/dashboard/logout" class="logout-btn">Logout</a>
    </div>
  </div>

  <div class="stats">
    <div class="stat-card">
      <h3>Total Verified</h3>
      <h2><%= stats.totalVerified %></h2>
    </div>
    <div class="stat-card">
      <h3>Open Tickets</h3>
      <h2><%= stats.openTickets || 0 %></h2>
    </div>
  </div>

  <h2>Recent Users</h2>
  <table>
    <thead>
      <tr>
        <th>Discord ID</th>
        <th>Roblox Username</th>
        <th>Verified</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% recentUsers.forEach(u => { %>
        <tr>
          <td><%= u.discordId %></td>
          <td><%= u.robloxUsername || '—' %></td>
          <td><%= u.verifiedAt ? '✅' : '❌' %></td>
          <td><a href="/api/users/<%= u.discordId %>" target="_blank">View Full Profile</a></td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <% if (isOwner) { %>
    <div class="owner-section">
      <h2>👑 Owner Controls</h2>
      <p>Management features coming soon (add staff, etc.)</p>
    </div>
  <% } %>
</body>
</html>